<Window x:Class="Snake_game.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Snake_game"
        mc:Ignorable="d"
        Title="Snake" Height="500" Width="800"
        MinWidth="300" MinHeight="300"
        Background="{StaticResource BackgroundColor}"
        Foreground="{StaticResource TextColor}"
        FontFamily="{StaticResource MainFont}"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/icon.ico"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="UpTriangleButton" TargetType="Button">
            <Setter Property="Background" Value="#FF4F4867"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Polygon x:Name="Triangle" Points="0,30 15,0 30,30" Fill="{TemplateBinding Background}" Stretch="Fill"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Triangle" Property="Fill" Value="#FF6A56AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Triangle" Property="Fill" Value="#FF39247F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DownTriangleButton" TargetType="Button">
            <Setter Property="Background" Value="#FF4F4867"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Polygon x:Name="Triangle" Points="0,0 30,0 15,30" Fill="{TemplateBinding Background}" Stretch="Fill"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Triangle" Property="Fill" Value="#FF6A56AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Triangle" Property="Fill" Value="#FF39247F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Viewbox>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Width="400" Margin="0,10,0,10">
                <TextBlock x:Name="ScoreText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="Score 0"
                           FontSize="22"/>

                <Button x:Name="OpenMenuButton"
                        Content="МЕНЮ"
                        VerticalAlignment="Center"
                        Padding="15,5"
                        FontSize="16"
                        FontFamily="Arial"
                        FontWeight="Bold"
                        Background="#FF4F4867"
                        Foreground="White"
                        BorderBrush="#FF281664"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="OpenMenuButton_Click"
                        Margin="316,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <Border x:Name="GridBorder"
                    Grid.Row="1"
                    BorderBrush="{StaticResource GridLineColor}"
                    BorderThickness="1.5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    RenderOptions.EdgeMode="Aliased"
                    Margin="20,0,20,20">

                <Grid Width="400" Height="400">
                    <UniformGrid x:Name="GameGrid"
                                 Background="{StaticResource GridBackgroundColor}"
                                 SnapsToDevicePixels="True"
                                 RenderOptions.BitmapScalingMode="HighQuality">
                    </UniformGrid>

                    <UniformGrid x:Name="FogGrid"
                                 SnapsToDevicePixels="True"
                                 RenderOptions.BitmapScalingMode="HighQuality"
                                 IsHitTestVisible="False">
                    </UniformGrid>
                </Grid>
            </Border>

            <Border x:Name="Overlay"
                    Grid.Row="1"
                    Background="{StaticResource OverlayColor}"
                    Width="{Binding Path=ActualHeight, ElementName=GridBorder}"
                    Height="{Binding Path=ActualHeight, ElementName=GridBorder}"
                    Margin="{Binding Path=Margin, ElementName=GridBorder}"
                    RenderOptions.EdgeMode="Aliased">
                <TextBlock x:Name="OverlayText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="PRESS ANY KEY TO START"
                           FontSize="26"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </Border>

            <Grid x:Name="SkinSelectorMenu" Grid.Row="1" Background="#E61E1E1E" Visibility="Collapsed" Panel.ZIndex="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                    <UniformGrid Columns="4" Rows="1" Margin="5">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Snake" Foreground="LightGray" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <Button Style="{StaticResource UpTriangleButton}" Width="35" Height="20" Click="BtnSnakeUp_Click" Cursor="Hand"/>
                            <Image x:Name="SnakeImageDisplay" Width="45" Height="45" Margin="0,10" RenderOptions.BitmapScalingMode="HighQuality" RenderTransformOrigin="0.5,0.5">
                                <Image.RenderTransform>
                                    <RotateTransform Angle="90"/>
                                </Image.RenderTransform>
                            </Image>
                            <Button Style="{StaticResource DownTriangleButton}" Width="35" Height="20" Click="BtnSnakeDown_Click" Cursor="Hand"/>
                        </StackPanel>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Fruit" Foreground="LightGray" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <Button Style="{StaticResource UpTriangleButton}" Width="35" Height="20" Click="BtnFoodUp_Click" Cursor="Hand"/>
                            <Grid Width="45" Height="45" Margin="0,10">
                                <Image x:Name="FoodImageDisplay" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Grid>
                            <Button Style="{StaticResource DownTriangleButton}" Width="35" Height="20" Click="BtnFoodDown_Click" Cursor="Hand"/>
                        </StackPanel>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Quantity of fruits" Foreground="LightGray" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <Button Style="{StaticResource UpTriangleButton}" Width="35" Height="20" Click="BtnFoodCountUp_Click" Cursor="Hand"/>
                            <TextBlock x:Name="FoodCountText" Text="1" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,18" HorizontalAlignment="Center"/>
                            <Button Style="{StaticResource DownTriangleButton}" Width="35" Height="20" Click="BtnFoodCountDown_Click" Cursor="Hand"/>
                        </StackPanel>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Map" Foreground="LightGray" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            <Button Style="{StaticResource UpTriangleButton}" Width="35" Height="20" Click="BtnMapUp_Click" Cursor="Hand"/>
                            <TextBlock x:Name="MapSizeText" Text="15x15" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,22" HorizontalAlignment="Center"/>
                            <Button Style="{StaticResource DownTriangleButton}" Width="35" Height="20" Click="BtnMapDown_Click" Cursor="Hand"/>
                        </StackPanel>
                    </UniformGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,30,0">
                            <TextBlock Text="Mode" Foreground="LightGray" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <Image Source="Assets/Glasses.png" Width="45" Height="45" Margin="0,0,0,10" RenderOptions.BitmapScalingMode="HighQuality"/>

                            <Button x:Name="BtnToggleBlindMode" 
                                    Content="NORMAL" 
                                    Width="80" Height="30" 
                                    Background="#FF4F4867" 
                                    Foreground="White" 
                                    Cursor="Hand" 
                                    FontWeight="Bold"
                                    BorderBrush="#FF281664"
                                    Click="BtnToggleBlindMode_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="3" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Speed" Foreground="LightGray" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="H" Foreground="LightGray" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Margin="0,0,15,0"/>

                                <Slider x:Name="SpeedSlider" 
                                        Width="200"
                                        Minimum="50" 
                                        Maximum="250" 
                                        Value="120" 
                                        TickFrequency="10" 
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="SpeedSlider_ValueChanged"
                                        Cursor="Hand"
                                        VerticalAlignment="Center">
                                    <Slider.Template>
                                        <ControlTemplate TargetType="Slider">
                                            <Grid VerticalAlignment="Center">
                                                <Border Height="4" Background="#FF4F4867" CornerRadius="2" Margin="7,0"/>

                                                <Track x:Name="PART_Track">
                                                    <Track.DecreaseRepeatButton>
                                                        <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                                            <RepeatButton.Template>
                                                                <ControlTemplate TargetType="RepeatButton">
                                                                    <Border Background="Transparent"/>
                                                                </ControlTemplate>
                                                            </RepeatButton.Template>
                                                        </RepeatButton>
                                                    </Track.DecreaseRepeatButton>

                                                    <Track.IncreaseRepeatButton>
                                                        <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                                            <RepeatButton.Template>
                                                                <ControlTemplate TargetType="RepeatButton">
                                                                    <Border Background="Transparent"/>
                                                                </ControlTemplate>
                                                            </RepeatButton.Template>
                                                        </RepeatButton>
                                                    </Track.IncreaseRepeatButton>

                                                    <Track.Thumb>
                                                        <Thumb>
                                                            <Thumb.Template>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border x:Name="thumbBorder" 
                                                                            Background="#FF6A56AF" 
                                                                            BorderBrush="#FF39247F" 
                                                                            BorderThickness="1" 
                                                                            CornerRadius="3" 
                                                                            Width="14" Height="24"/>

                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="thumbBorder" Property="Background" Value="#FF8E79E0"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsDragging" Value="True">
                                                                            <Setter TargetName="thumbBorder" Property="Background" Value="#FF4F3D91"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Thumb.Template>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Slider.Template>
                                </Slider>

                                <TextBlock Text="L" Foreground="LightGray" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Margin="15,0,0,0"/>
                            </StackPanel>

                            <TextBlock x:Name="SpeedValueText" Text="120 ms" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                        </StackPanel>

                    </StackPanel>

                </StackPanel>
            </Grid>

        </Grid>
    </Viewbox>
</Window>